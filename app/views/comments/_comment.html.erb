<div class="d-flex gap-3 mb-3">
  <div class="flex-shrink-0">
    <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
      <i class="bi bi-person-fill text-white"></i>
    </div>
  </div>
  <div class="flex-grow-1">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <strong><%= link_to comment.user.username, profile_path(comment.user.username), class: "text-decoration-none" %></strong>
        <small class="text-muted ms-2"><%= time_ago_in_words(comment.created_at) %> назад</small>
      </div>
      <% if user_signed_in? && (current_user == comment.user || current_user.admin?) %>
        <% delete_path = commentable.is_a?(Article) ? article_comment_path(commentable, comment) : game_review_comment_path(commentable.game, commentable, comment) %>
        <%= button_to delete_path, method: :delete,
              class: "btn btn-outline-danger btn-sm",
              data: { turbo_confirm: "Удалить комментарий?" } do %>
          <i class="bi bi-trash"></i>
        <% end %>
      <% end %>
    </div>
    <p class="mb-0"><%= comment.body %></p>
  </div>
</div>
