<div class="container py-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Игры", games_path %></li>
      <li class="breadcrumb-item active"><%= @game.title %></li>
    </ol>
  </nav>

  <div class="row">
    <div class="col-lg-4 mb-4">
      <% if @game.cover_image.present? %>
        <img src="<%= @game.cover_image %>" class="img-fluid rounded shadow" alt="<%= @game.title %>">
      <% else %>
        <div class="bg-secondary rounded d-flex align-items-center justify-content-center shadow" style="height: 300px;">
          <i class="bi bi-controller text-white" style="font-size: 5rem;"></i>
        </div>
      <% end %>
    </div>

    <div class="col-lg-8">
      <div class="d-flex justify-content-between align-items-start">
        <h1><%= @game.title %></h1>
        <% if user_signed_in? && current_user.admin? %>
          <div class="btn-group">
            <%= link_to edit_game_path(@game), class: "btn btn-outline-primary btn-sm" do %>
              <i class="bi bi-pencil"></i> Редактировать
            <% end %>
            <%= button_to game_path(@game), method: :delete,
                  class: "btn btn-outline-danger btn-sm",
                  data: { turbo_confirm: "Удалить игру?" } do %>
              <i class="bi bi-trash"></i> Удалить
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="d-flex flex-wrap gap-2 mb-3">
        <% @game.genres.each do |genre| %>
          <%= link_to genre.name, games_path(genre_id: genre.id), class: "badge bg-info text-decoration-none" %>
        <% end %>
      </div>

      <div class="row mb-3">
        <div class="col-auto">
          <span class="text-warning fs-4"><i class="bi bi-star-fill"></i></span>
          <strong class="fs-4"><%= number_with_precision(@game.average_rating, precision: 1) %></strong>
          <span class="text-muted">/ 10</span>
          <small class="text-muted">(<%= @game.reviews.count %> отзывов)</small>
        </div>
      </div>

      <table class="table table-borderless">
        <% if @game.developer.present? %>
          <tr><th class="text-muted" style="width: 150px;">Разработчик</th><td><%= @game.developer %></td></tr>
        <% end %>
        <% if @game.publisher.present? %>
          <tr><th class="text-muted">Издатель</th><td><%= @game.publisher %></td></tr>
        <% end %>
        <% if @game.release_date.present? %>
          <tr><th class="text-muted">Дата выхода</th><td><%= @game.release_date.strftime("%d.%m.%Y") %></td></tr>
        <% end %>
      </table>

      <% if @game.description.present? %>
        <h5>Описание</h5>
        <p><%= simple_format(@game.description) %></p>
      <% end %>
    </div>
  </div>

  <hr>

  <div class="row">
    <div class="col-lg-8">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-chat-dots"></i> Отзывы</h3>
        <% if user_signed_in? && !@game.reviews.exists?(user: current_user) %>
          <%= link_to new_game_review_path(@game), class: "btn btn-primary" do %>
            <i class="bi bi-plus-lg"></i> Написать отзыв
          <% end %>
        <% end %>
      </div>

      <% if @reviews.any? %>
        <% @reviews.each do |review| %>
          <%= render "reviews/review", review: review %>
        <% end %>
        <div class="d-flex justify-content-center mt-3">
          <%= paginate @reviews %>
        </div>
      <% else %>
        <p class="text-muted">Пока нет отзывов. Будьте первым!</p>
      <% end %>
    </div>
  </div>
</div>
