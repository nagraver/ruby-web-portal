<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-controller"></i> Каталог игр</h1>
    <% if user_signed_in? && current_user.admin? %>
      <%= link_to new_game_path, class: "btn btn-success" do %>
        <i class="bi bi-plus-lg"></i> Добавить игру
      <% end %>
    <% end %>
  </div>

  <div class="row">
    <div class="col-lg-3 mb-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Фильтры</h5>

          <%= form_tag games_path, method: :get, class: "mb-3" do %>
            <div class="mb-3">
              <label class="form-label">Поиск</label>
              <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Название игры..." %>
            </div>

            <div class="mb-3">
              <label class="form-label">Жанр</label>
              <%= select_tag :genre_id,
                    options_from_collection_for_select(@genres, :id, :name, params[:genre_id]),
                    include_blank: "Все жанры",
                    class: "form-select" %>
            </div>

            <%= submit_tag "Найти", class: "btn btn-primary w-100" %>
          <% end %>

          <% if params[:q].present? || params[:genre_id].present? %>
            <%= link_to "Сбросить фильтры", games_path, class: "btn btn-outline-secondary w-100" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <% if @games.any? %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
          <% @games.each do |game| %>
            <div class="col">
              <div class="card h-100 shadow-sm">
                <% if game.cover_image.present? %>
                  <img src="<%= game.cover_image %>" class="card-img-top" alt="<%= game.title %>" style="height: 200px; object-fit: cover;">
                <% else %>
                  <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                    <i class="bi bi-controller text-white" style="font-size: 3rem;"></i>
                  </div>
                <% end %>
                <div class="card-body">
                  <h5 class="card-title"><%= link_to game.title, game, class: "text-decoration-none" %></h5>
                  <p class="card-text text-muted small"><%= truncate(game.description, length: 100) %></p>
                  <div class="d-flex flex-wrap gap-1 mb-2">
                    <% game.genres.each do |genre| %>
                      <span class="badge bg-info"><%= genre.name %></span>
                    <% end %>
                  </div>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                  <span class="text-warning">
                    <i class="bi bi-star-fill"></i> <%= number_with_precision(game.average_rating, precision: 1) %>
                  </span>
                  <small class="text-muted"><%= game.release_date&.strftime("%d.%m.%Y") %></small>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="d-flex justify-content-center mt-4">
          <%= paginate @games %>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-controller text-muted" style="font-size: 4rem;"></i>
          <p class="text-muted mt-3">Игры не найдены</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
