<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title mb-1"><%= review.title %></h5>
        <p class="text-muted small mb-2">
          <i class="bi bi-person"></i>
          <%= link_to review.user.username, profile_path(review.user.username), class: "text-decoration-none" %>
          &bull; <%= review.created_at.strftime("%d.%m.%Y") %>
        </p>
      </div>
      <div class="text-end">
        <div class="d-flex align-items-center gap-1">
          <% 10.times do |i| %>
            <% if i < review.rating %>
              <i class="bi bi-star-fill text-warning"></i>
            <% else %>
              <i class="bi bi-star text-muted"></i>
            <% end %>
          <% end %>
        </div>
        <small class="text-muted"><%= review.rating %>/10</small>
      </div>
    </div>

    <p class="card-text"><%= simple_format(review.body) %></p>

    <% if user_signed_in? && (current_user == review.user || current_user.admin?) %>
      <div class="d-flex gap-2">
        <% if current_user == review.user %>
          <%= link_to edit_game_review_path(review.game, review), class: "btn btn-outline-primary btn-sm" do %>
            <i class="bi bi-pencil"></i> Редактировать
          <% end %>
        <% end %>
        <%= button_to game_review_path(review.game, review), method: :delete,
              class: "btn btn-outline-danger btn-sm",
              data: { turbo_confirm: "Удалить отзыв?" } do %>
          <i class="bi bi-trash"></i> Удалить
        <% end %>
      </div>
    <% end %>
  </div>
</div>
