<%= form_with(model: [game, review]) do |f| %>
  <% if review.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% review.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Заголовок", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, "Оценка (1-10)", class: "form-label" %>
    <%= f.select :rating, (1..10).to_a.reverse, { include_blank: "Выберите оценку" }, class: "form-select", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :body, "Текст отзыва", class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: 6, required: true %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-success" %>
    <%= link_to "Отмена", game, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
