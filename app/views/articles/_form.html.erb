<%= form_with(model: article, class: "needs-validation") do |f| %>
  <% if article.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% article.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Заголовок", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :body, "Текст статьи", class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: 12, required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :game_id, "Связанная игра", class: "form-label" %>
      <%= f.collection_select :game_id, @games, :id, :title,
            { include_blank: "— Не выбрана —" },
            { class: "form-select" } %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :published_at, "Дата публикации", class: "form-label" %>
      <%= f.datetime_local_field :published_at, class: "form-control" %>
      <div class="form-text">Оставьте пустым для черновика</div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-success" %>
    <%= link_to "Отмена", articles_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
