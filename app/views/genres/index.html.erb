<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-tags"></i> Жанры</h1>
    <%= link_to new_genre_path, class: "btn btn-success" do %>
      <i class="bi bi-plus-lg"></i> Добавить жанр
    <% end %>
  </div>

  <div class="card">
    <div class="card-body">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Название</th>
            <th>Кол-во игр</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @genres.each do |genre| %>
            <tr>
              <td><%= genre.name %></td>
              <td><%= genre.games.count %></td>
              <td class="text-end">
                <%= link_to edit_genre_path(genre), class: "btn btn-outline-primary btn-sm" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to genre_path(genre), method: :delete,
                      class: "btn btn-outline-danger btn-sm",
                      data: { turbo_confirm: "Удалить жанр?" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex justify-content-center mt-3">
    <%= paginate @genres %>
  </div>
</div>
